# CoreBank backend URL (default: http://localhost:9090)
CORE_BANK_URL=http://localhost:9090

# Demo user credentials — used server-side only, never sent to browser
CORE_BANK_USER=demo_user
CORE_BANK_PASS=demo_user

# Privileged demo setup credentials for POST /api/demo/setup.
# Keep separate from CORE_BANK_USER/CORE_BANK_PASS because setup requires OPS/ADMIN.
CORE_BANK_SETUP_USER=demo_ops
CORE_BANK_SETUP_PASS=demo_ops
